graph LR
    %% ===== ACTORS =====
    USER([User])

    %% ===== SYSTEM BLOCKS =====
    UI["Frontend\n(React + Tailwind)\n:3000"]
    API["Backend API\n(FastAPI)\n:8000"]
    ORCH["LangGraph\nOrchestrator"]
    LLM["Google Gemini 1.5 Pro"]
    OCR_TOOLS["OCR Tools\n(Tesseract + PyMuPDF)"]

    %% ===== FLOW =====
    USER -->|"Upload Invoice\n(PDF / Image)"| UI
    UI -->|"REST API"| API
